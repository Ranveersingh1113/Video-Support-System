# Caddy auto-manages TLS certificates from Let's Encrypt.
# PUBLIC_DOMAIN and ACME_EMAIL are injected via environment variables
# from docker-compose.prod.yml.

{
    email {$ACME_EMAIL}
}

# Main app — API + built web SPA, served from the same origin.
{$PUBLIC_DOMAIN} {
    encode gzip
    reverse_proxy app:4000
}

# LiveKit signaling — WebSocket upgrade is automatic with Caddy's reverse_proxy.
lk.{$PUBLIC_DOMAIN} {
    reverse_proxy livekit:7880
}
