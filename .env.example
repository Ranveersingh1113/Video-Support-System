# Copy to .env at repo root (and apps load via their own dotenv). Local dev values.

# --- API (Fastify) ---
PORT=4000
DATABASE_URL=postgresql://vsp:vsp_dev_pw@localhost:5432/vsp
JWT_SECRET=dev_jwt_secret_change_me_please_32chars
INVITE_TTL_MINUTES=120
MAX_UPLOAD_BYTES=5242880
BODY_LIMIT_BYTES=8388608
# Path as seen by the Docker egress worker. Host files appear under ./recordings.
EGRESS_RECORDING_DIR=/out/recordings
EGRESS_REQUEST_TIMEOUT_MS=8000

# --- LiveKit (must match your LiveKit server's configured keys) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret

# --- Web (Vite, must be VITE_ prefixed to reach the browser) ---
VITE_API_URL=http://localhost:4000
VITE_LIVEKIT_URL=ws://localhost:7880
