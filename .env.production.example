# Production environment — copy to .env.production and fill in real values.
# .env.production is gitignored (it holds secrets).
#
# Generate secrets:
#   openssl rand -hex 32   → JWT_SECRET, LIVEKIT_API_SECRET
#   openssl rand -hex 16   → LIVEKIT_API_KEY, POSTGRES_PASSWORD

# --- Domain / TLS (used by Caddy) ---
PUBLIC_DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com

# --- App URLs ---
PUBLIC_WEB_URL=https://yourdomain.com
# Public LiveKit signaling URL the BROWSER connects to. Feeds both the web build
# (VITE_LIVEKIT_URL) and the API's LIVEKIT_PUBLIC_URL (see docker-compose.prod.yml).
VITE_LIVEKIT_URL=wss://lk.yourdomain.com

# --- API ---
PORT=4000
JWT_SECRET=<openssl rand -hex 32>
INVITE_TTL_MINUTES=120
MAX_UPLOAD_BYTES=5242880
BODY_LIMIT_BYTES=8388608

# --- Database ---
POSTGRES_USER=vsp
POSTGRES_PASSWORD=<openssl rand -hex 16>
POSTGRES_DB=vsp
DATABASE_URL=postgresql://vsp:<POSTGRES_PASSWORD>@postgres:5432/vsp

# --- LiveKit (must match infra/livekit-prod.yaml keys block) ---
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=<openssl rand -hex 16>
LIVEKIT_API_SECRET=<openssl rand -hex 32>
