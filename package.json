{
  "name": "video-support-platform",
  "private": true,
  "version": "0.1.0",
  "description": "AtomQuest finale — self-hosted real-time video support platform (LiveKit SFU)",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "smoke": "npm run smoke --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
